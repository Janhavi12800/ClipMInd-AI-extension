# TechShield AI — Docker Environment Variables

# Frontend build args
VITE_API_URL=https://your-project.supabase.co/functions/v1
VITE_PAYMENTS_URL=https://your-project.supabase.co/functions/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_DEMO_MODE=true

# Monitoring
GRAFANA_PASSWORD=change-me-in-production
GRAFANA_URL=https://monitoring.techshield.ai

# Backup
SUPABASE_DB_URL=postgresql://postgres:password@host:5432/postgres
BACKUP_S3_BUCKET=techshield-backups
BACKUP_RETENTION_DAYS=30
