{
  "manifest_version": 3,
  "name": "TradePrompt AI — Smart Trading Prompts",
  "version": "1.0.4",
  "description": "Professional AI prompt engineering for Indian stocks (NSE/BSE), Forex & Crypto. 1-click chart analysis with vision AI.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.tradingview.com/*",
    "https://in.tradingview.com/*",
    "https://www.nseindia.com/*",
    "https://api.coingecko.com/*",
    "https://api.alternative.me/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.tradeprompt.ai/*",
    "https://*.onrender.com/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*",
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://api.frankfurter.app/*",
    "http://localhost:3001/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://api.tradeprompt.ai/*",
      "https://*.onrender.com/*",
      "https://*.up.railway.app/*",
      "http://localhost:3001/*"
    ]
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "TradePrompt AI"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.tradingview.com/*",
        "https://in.tradingview.com/*"
      ],
      "js": ["content/tradingview.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "lib/*"],
      "matches": ["https://*.tradingview.com/*"]
    }
  ]
}
