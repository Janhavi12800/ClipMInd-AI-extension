# TechShield AI — Environment Variables

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application
SITE_URL=http://localhost:5173

# Google OAuth (configure in Supabase Dashboard → Authentication → Providers)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Security
IP_HASH_SALT=change-this-to-a-random-32-char-string

# Stripe (optional, for billing integration)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Encryption key for encrypted_secrets table (32 bytes, base64)
ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
